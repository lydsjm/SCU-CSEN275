' === Relationships ===
garden *-- tempSys : tempSystem
garden *-- waterSys : wateringSystem
garden *-- pestSys : pestSystem
garden *-- pestInv : pesticideInv
garden *-- pestList : currentPests
garden *-- grid : gardenLogicMap
garden *-- deathToll : deathToll

grid -- tomato1 : "[5][10]"
grid -- chili1 : "[3][14]"
grid -- kale1 : "[8][7]"
grid -- cabbage1 : "[12][20]"
grid -- radish1 : "[6][16]"
grid -- carrot1 : "[15][9]"
grid -- coriander1 : "[10][22] (dead)"

tempSys .. garden : monitors\ngreenhouse temp
waterSys .. garden : monitors\nplant water levels
pestSys .. pestList : selects random\npest to treat
pestSys .. pestInv : consumes\npesticide

